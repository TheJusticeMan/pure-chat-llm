{
  "name": "pure-chat-llm",
  "version": "2.1.0",
  "description": "Turn notes into conversations with chatGPT",
  "main": "main.js",
  "scripts": {
    "dev": "node scripts/esbuild.config.mjs",
    "format": "prettier --write \"src/**/*.ts\" && prettier --write \"scripts/*.sh\" && prettier --write \"**/*.md\"",
    "build": "tsc -noEmit -skipLibCheck && node scripts/esbuild.config.mjs production",
    "version": "node scripts/version-bump.mjs && git add manifest.json versions.json src/assets/s.json",
    "release": "bash scripts/Release.sh",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "copy-to-mobile-vault": "kioclient5 --overwrite copy styles.css manifest.json main.js \"mtp:/Armor X31 Pro/Internal shared storage/Documents/Obsidian/.obsidian/plugins/pure-chat-llm/\"",
    "knip": "knip"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "chatbot",
    "language model",
    "LLM",
    "notes"
  ],
  "author": "Justice Vellacott",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/language": "^6.11.3",
    "@codemirror/view": "6.38.6",
    "@eslint/js": "^10.0.1",
    "@types/glob-to-regexp": "^0.4.4",
    "@types/node": "^25.8.0",
    "@typescript-eslint/parser": "^8.59.3",
    "builtin-modules": "^5.2.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "globals": "^17.6.0",
    "knip": "^6.14.0",
    "obsidian": "latest",
    "prettier": "^3.8.3",
    "prettier-plugin-sh": "^0.18.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  },
  "dependencies": {
    "apocalypse-throttle": "^0.0.0",
    "diff": "^9.0.0",
    "glob-to-regexp": "^0.4.1"
  }
}
