{
  "compilerOptions": {
    "resolveJsonModule": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES6",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["es2023", "DOM", "DOM.Iterable"],
    "paths": {
      "*": ["./*"]
    }
  },
  "include": ["**/*.ts"]
}
